{
  "name": "ya-messenger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc -p . && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "format:fix": "prettier --write \"src/**/*.{ts,js,json,hbs,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,hbs,md}\"",
    "lint:ts": "eslint \"src/**/*.{js,ts}\"",
    "lint:ts:fix": "eslint --fix \"**/*.{js,ts}\"",
    "lint:css": "stylelint **/*.css",
    "lint:css:fix": "stylelint --fix **/*.css",
    "lint": "npm run lint:ts && npm run lint:css",
    "test": "jest"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@conarti/eslint-plugin-feature-sliced": "^1.0.5",
    "@eslint/js": "^9.25.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.1",
    "@types/testing-library__jest-dom": "^5.14.9",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.25.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-transform-stub": "^2.0.0",
    "postcss": "^8.5.6",
    "prettier": "3.8.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1"
  }
}
