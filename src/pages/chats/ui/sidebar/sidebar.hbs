<aside class="{{styles.sidebar}}">
  <form class="{{styles.chat-adding__form}}">
    <label>
      <span>Новый чат</span>
      <input
        class="{{styles.chat-adding__input}}"
        type="text"
        placeholder="Название"
        name="title"
        maxlength="20"
      />
    </label>
    {{{BaseButton
      ref=this.componentName
      title="Добавить чат"
      type="submit"
      additionalStyles=styles.chat-adding__adding-button
    }}}
  </form>

  <nav class="{{styles.sidebar__chats}}">
    {{#each chats}}
      <div class="{{../styles.sidebar__chat}}">
        {{{ChatItem
                id=this.id
                avatarUrl=this.avatarUrl
                title=this.title
                unreadCount=this.unreadCount
                lastMessage=this.lastMessage
                ref=this.componentName
        }}}

        {{#if (eq this.createdBy ../userId)}}
          <button class="delete-chat {{../styles.sidebar__delete-chat}}" type="button" data-id="{{this.id}}">{{{../deleteIcon}}}</button>

        {{/if}}
         </div>
    {{/each}}
  </nav>

  <div class="{{styles.sidebar__link}}">
    {{{BaseLink title="Профиль" href=profileLink ref=this.componentName}}}
  </div>
</aside>