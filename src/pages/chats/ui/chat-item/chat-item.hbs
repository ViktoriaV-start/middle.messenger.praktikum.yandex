
  <button class="chat-item {{styles.chat-item}} {{unreadCountClass}} {{#if active}}{{styles.chat-item__active}}{{/if}}" data-id="{{id}}">
    <div class="{{styles.avatar}}">
      <img src="{{avatarUrl}}" alt="avatar" />
    </div>

    <div class="{{styles.name}}">
      {{title}}

      {{#with lastMessage}}
        <time class="{{styles.date}}" datetime="{{time}}">
          {{time}}
        </time>
      {{/with}}
    </div>

    {{#with lastMessage}}
      <div class="{{styles.message}}">
        {{{text}}}
      </div>
    {{/with}}

    {{#if unreadCount}}
      <span class="{{styles.badge}}">
        {{unreadCount}}
      </span>
    {{/if}}
  </button>
