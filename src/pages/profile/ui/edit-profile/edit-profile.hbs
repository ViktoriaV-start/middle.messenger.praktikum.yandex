<div class="{{styles.profile__wrapper}}">
  {{{BackButton ref="back"}}}
  <form class="profile {{styles.profile}}">
    {{{Navigation}}}
    <div class="{{styles.profile__avatar}} {{styles.edit-profile__avatar_mbe}}" id="avatar"></div>

    <div class="{{styles.profile__inputs}} {{styles.profile__inputs_mbe}}">
      {{#each profileInputs}}
        {{{Input
          type=this.type
          label=this.label
          placeholder=this.placeholder
          name=this.name
          ref=this.name
          value=(lookup @root.user this.name)
          isEditable=true
        }}}
      {{/each}}
    </div>

    {{{BaseButton title=button.title additionalStyles=styles.profile__save-button}}}

  </form>

</div>