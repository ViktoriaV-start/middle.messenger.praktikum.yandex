<label class="{{styles.input__label}}">
  <span class="{{styles.input__label-text}}">{{input.label}}</span>
  <input
    class="input-auth {{styles.input__field}}"
    type="{{input.type}}"
    placeholder="{{input.placeholder}}"
    name="{{input.name}}"
    readonly="{{editable}}"
    value="{{input.value}}"
  />
</label>
